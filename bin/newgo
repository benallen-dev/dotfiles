#!/usr/bin/env zsh

# Bootstraps a new Go project

name=$1

if [ -z $name ]; then
	echo "Usage: newgo <project name>"
	exit 1
fi

mkdir $name
cd $name # Would be nice to actually cd in here

go mod init $name

# MAIN
echo "package main

import (
	\"fmt\"
)

func main() {
	fmt.Println(\"Hello, World!\")
}" > main.go

# README
echo "# $name

## Usage

\`\`\`
go run .
\`\`\`" > README.md

# Makefile
echo "run:
	go run main.go" > Makefile

# Git
git init
echo "bin
tmp" > .gitignore
git add .

# Air
air init

# Done
